              SQLTask:SqlStatementSource="USE DatawareHouse_BankTransactionFraund;&#xA;GO&#xA;&#xA;-- DIM_CUSTOMER_LOCATION&#xA;IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='DIM_CUSTOMER_LOCATION' AND xtype='U')&#xA;BEGIN&#xA;CREATE TABLE DIM_CUSTOMER_LOCATION (&#xA;    CUSTOMER_LOCATION_ID INT IDENTITY(1,1) PRIMARY KEY,&#xA;    State NVARCHAR(100),&#xA;    City NVARCHAR(100)&#xA;);&#xA;END&#xA;&#xA;-- DIM_CONTACT&#xA;IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='DIM_CONTACT' AND xtype='U')&#xA;BEGIN&#xA;CREATE TABLE DIM_CONTACT (&#xA;    CONTACT_ID INT IDENTITY(1,1) PRIMARY KEY,&#xA;    Customer_Email NVARCHAR(255),&#xA;    Customer_Contact NVARCHAR(50)&#xA;);&#xA;END&#xA;&#xA;-- DIM_CUSTOMER&#xA;IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='DIM_CUSTOMER' AND xtype='U')&#xA;BEGIN&#xA;CREATE TABLE DIM_CUSTOMER (&#xA;    CUSTOMER_ID INT IDENTITY(1,1) PRIMARY KEY,&#xA;    Customer_Name NVARCHAR(255),&#xA;    Gender NVARCHAR(50),&#xA;    Age INT,&#xA;    CUSTOMER_LOCATION_ID INT,&#xA;    CONTACT_ID INT&#xA;);&#xA;END&#xA;&#xA;-- DIM_DEVICE_TYPE&#xA;IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='DIM_DEVICE_TYPE' AND xtype='U')&#xA;BEGIN&#xA;CREATE TABLE DIM_DEVICE_TYPE (&#xA;    DEVICE_TYPE_ID INT IDENTITY(1,1) PRIMARY KEY,&#xA;    Device_Type NVARCHAR(100)&#xA;);&#xA;END&#xA;&#xA;-- DIM_DEVICE&#xA;IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='DIM_DEVICE' AND xtype='U')&#xA;BEGIN&#xA;CREATE TABLE DIM_DEVICE (&#xA;    DEVICE_ID INT IDENTITY(1,1) PRIMARY KEY,&#xA;    Transaction_Device NVARCHAR(100),&#xA;    DEVICE_TYPE_ID INT&#xA;);&#xA;END&#xA;&#xA;-- DIM_LOCATION_TRANSACTION&#xA;IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='DIM_LOCATION_TRANSACTION' AND xtype='U')&#xA;BEGIN&#xA;CREATE TABLE DIM_LOCATION_TRANSACTION (&#xA;    LOCATION_TRANSACTION_ID INT IDENTITY(1,1) PRIMARY KEY,&#xA;    Transaction_State NVARCHAR(100),&#xA;    Transaction_City NVARCHAR(100)&#xA;);&#xA;END&#xA;&#xA;-- DIM_BANK_BRANCH&#xA;IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='DIM_BANK_BRANCH' AND xtype='U')&#xA;BEGIN&#xA;CREATE TABLE DIM_BANK_BRANCH (&#xA;    BANK_BRANCH_ID INT IDENTITY(1,1) PRIMARY KEY,&#xA;    Bank_Branch NVARCHAR(255)&#xA;);&#xA;END&#xA;&#xA;-- DIM_TRANSACTION_TYPE&#xA;IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='DIM_TRANSACTION_TYPE' AND xtype='U')&#xA;BEGIN&#xA;CREATE TABLE DIM_TRANSACTION_TYPE (&#xA;    TRANSACTION_TYPE_ID INT IDENTITY(1,1) PRIMARY KEY,&#xA;    Transaction_Type NVARCHAR(100)&#xA;);&#xA;END&#xA;&#xA;-- DIM_MERCHANT&#xA;IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='DIM_MERCHANT' AND xtype='U')&#xA;BEGIN&#xA;CREATE TABLE DIM_MERCHANT (&#xA;    MERCHANT_ID INT IDENTITY(1,1) PRIMARY KEY,&#xA;    Merchant_Category NVARCHAR(100)&#xA;);&#xA;END&#xA;&#xA;-- DIM_TYPE&#xA;IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='DIM_TYPE' AND xtype='U')&#xA;BEGIN&#xA;CREATE TABLE DIM_TYPE (&#xA;    TYPE_ID INT IDENTITY(1,1) PRIMARY KEY,&#xA;    Account_Type NVARCHAR(100)&#xA;);&#xA;END&#xA;&#xA;-- DIM_TIME&#xA;IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='DIM_TIME' AND xtype='U')&#xA;BEGIN&#xA;CREATE TABLE DIM_TIME (&#xA;    TIME_ID INT IDENTITY(1,1) PRIMARY KEY,&#xA;    Hour INT,&#xA;    Minute INT,&#xA;    Second INT&#xA;);&#xA;END&#xA;&#xA;-- DIM_DATE&#xA;IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='DIM_DATE' AND xtype='U')&#xA;BEGIN&#xA;CREATE TABLE DIM_DATE (&#xA;    DATE_ID INT IDENTITY(1,1) PRIMARY KEY,&#xA;    Year INT,&#xA;    Month INT,&#xA;    Day INT,&#xA;    TIME_ID INT&#xA;);&#xA;END&#xA;&#xA;-- FACT_TRANSACTION&#xA;IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='FACT_TRANSACTION' AND xtype='U')&#xA;BEGIN&#xA;CREATE TABLE FACT_TRANSACTION (&#xA;    FACT_ID INT IDENTITY(1,1) PRIMARY KEY,&#xA;    Transaction_Amount DECIMAL(18,2),&#xA;    Account_Balance DECIMAL(18,2),&#xA;    Is_Fraud BIT,&#xA;    TRANSACTION_TYPE_ID INT,&#xA;    CUSTOMER_ID INT,&#xA;    BANK_BRANCH_ID INT,&#xA;    TYPE_ID INT,&#xA;    DATE_ID INT,&#xA;    MERCHANT_ID INT,&#xA;    DEVICE_ID INT,&#xA;    LOCATION_TRANSACTION_ID INT&#xA;);&#xA;END&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
