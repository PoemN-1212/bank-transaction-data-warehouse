              SQLTask:Connection="{1C0C19E1-E741-44EB-B5EE-9EAEE672F690}"
              SQLTask:SqlStatementSource="USE DatawareHouse_BankTransactionFraund;&#xA;GO&#xA;&#xA;DECLARE @sql NVARCHAR(MAX) = N'';&#xA;&#xA;SELECT @sql += '&#xA;ALTER TABLE [' + OBJECT_SCHEMA_NAME(parent_object_id) + '].[' + OBJECT_NAME(parent_object_id) + '] &#xA;DROP CONSTRAINT [' + name + '];'&#xA;FROM sys.foreign_keys;&#xA;&#xA;EXEC sp_executesql @sql;&#xA;&#xA;&#xA;&#xA;TRUNCATE TABLE FACT_TRANSACTION;&#xA;&#xA;TRUNCATE TABLE DIM_TRANSACTION_TYPE;&#xA;TRUNCATE TABLE DIM_CUSTOMER;&#xA;TRUNCATE TABLE DIM_BANK_BRANCH;&#xA;TRUNCATE TABLE DIM_DATE;&#xA;TRUNCATE TABLE DIM_TYPE;&#xA;TRUNCATE TABLE DIM_MERCHANT;&#xA;TRUNCATE TABLE DIM_DEVICE;&#xA;TRUNCATE TABLE DIM_DEVICE_TYPE;&#xA;TRUNCATE TABLE DIM_LOCATION_TRANSACTION;&#xA;TRUNCATE TABLE DIM_CUSTOMER_LOCATION;&#xA;TRUNCATE TABLE DIM_CONTACT;&#xA;TRUNCATE TABLE DIM_TIME;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
