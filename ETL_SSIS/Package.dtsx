          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{1C0C19E1-E741-44EB-B5EE-9EAEE672F690}"
              SQLTask:SqlStatementSource="USE DatawareHouse_BankTransactionFraund;&#xA;GO&#xA;&#xA;-- ============================&#xA;-- DIM_CUSTOMER&#xA;-- ============================&#xA;&#xA;-- FK đến DIM_CUSTOMER_LOCATION&#xA;IF EXISTS (SELECT * FROM sys.foreign_keys WHERE name = 'FK_DIM_CUSTOMER_LOCATION')&#xA;    ALTER TABLE DIM_CUSTOMER DROP CONSTRAINT FK_DIM_CUSTOMER_LOCATION;&#xA;ALTER TABLE DIM_CUSTOMER&#xA;ADD CONSTRAINT FK_DIM_CUSTOMER_LOCATION&#xA;FOREIGN KEY (CUSTOMER_LOCATION_ID)&#xA;REFERENCES DIM_CUSTOMER_LOCATION(CUSTOMER_LOCATION_ID);&#xA;&#xA;-- FK đến DIM_CONTACT&#xA;IF EXISTS (SELECT * FROM sys.foreign_keys WHERE name = 'FK_DIM_CUSTOMER_CONTACT')&#xA;    ALTER TABLE DIM_CUSTOMER DROP CONSTRAINT FK_DIM_CUSTOMER_CONTACT;&#xA;ALTER TABLE DIM_CUSTOMER&#xA;ADD CONSTRAINT FK_DIM_CUSTOMER_CONTACT&#xA;FOREIGN KEY (CONTACT_ID)&#xA;REFERENCES DIM_CONTACT(CONTACT_ID);&#xA;&#xA;-- FK đến DIM_TIME&#xA;IF EXISTS (SELECT * FROM sys.foreign_keys WHERE name = 'FK_DATE_TIME')&#xA;    ALTER TABLE DIM_DATE DROP CONSTRAINT FK_DATE_TIME;&#xA;&#xA;ALTER TABLE DIM_DATE&#xA;ADD CONSTRAINT FK_DATE_TIME&#xA;FOREIGN KEY (TIME_ID)&#xA;REFERENCES DIM_TIME(TIME_ID);&#xA;&#xA;&#xA;-- ============================&#xA;-- DIM_DEVICE&#xA;-- ============================&#xA;&#xA;-- FK đến DIM_DEVICE_TYPE&#xA;IF EXISTS (SELECT * FROM sys.foreign_keys WHERE name = 'FK_DIM_DEVICE_TYPE')&#xA;    ALTER TABLE DIM_DEVICE DROP CONSTRAINT FK_DIM_DEVICE_TYPE;&#xA;ALTER TABLE DIM_DEVICE&#xA;ADD CONSTRAINT FK_DIM_DEVICE_TYPE&#xA;FOREIGN KEY (DEVICE_TYPE_ID)&#xA;REFERENCES DIM_DEVICE_TYPE(DEVICE_TYPE_ID);&#xA;&#xA;-- ============================&#xA;-- FACT_TRANSACTION&#xA;-- ============================&#xA;&#xA;-- FK đến DIM_CUSTOMER&#xA;IF EXISTS (SELECT * FROM sys.foreign_keys WHERE name = 'FK_FACT_CUSTOMER')&#xA;    ALTER TABLE FACT_TRANSACTION DROP CONSTRAINT FK_FACT_CUSTOMER;&#xA;ALTER TABLE FACT_TRANSACTION&#xA;ADD CONSTRAINT FK_FACT_CUSTOMER&#xA;FOREIGN KEY (CUSTOMER_ID) REFERENCES DIM_CUSTOMER(CUSTOMER_ID);&#xA;&#xA;-- FK đến DIM_BANK_BRANCH&#xA;IF EXISTS (SELECT * FROM sys.foreign_keys WHERE name = 'FK_FACT_BRANCH')&#xA;    ALTER TABLE FACT_TRANSACTION DROP CONSTRAINT FK_FACT_BRANCH;&#xA;ALTER TABLE FACT_TRANSACTION&#xA;ADD CONSTRAINT FK_FACT_BRANCH&#xA;FOREIGN KEY (BANK_BRANCH_ID) REFERENCES DIM_BANK_BRANCH(BANK_BRANCH_ID);&#xA;&#xA;-- FK đến DIM_TYPE&#xA;IF EXISTS (SELECT * FROM sys.foreign_keys WHERE name = 'FK_FACT_TYPE')&#xA;    ALTER TABLE FACT_TRANSACTION DROP CONSTRAINT FK_FACT_TYPE;&#xA;ALTER TABLE FACT_TRANSACTION&#xA;ADD CONSTRAINT FK_FACT_TYPE&#xA;FOREIGN KEY (TYPE_ID) REFERENCES DIM_TYPE(TYPE_ID);&#xA;&#xA;-- FK đến DIM_DATE&#xA;IF EXISTS (SELECT * FROM sys.foreign_keys WHERE name = 'FK_FACT_DATE')&#xA;    ALTER TABLE FACT_TRANSACTION DROP CONSTRAINT FK_FACT_DATE;&#xA;ALTER TABLE FACT_TRANSACTION&#xA;ADD CONSTRAINT FK_FACT_DATE&#xA;FOREIGN KEY (DATE_ID) REFERENCES DIM_DATE(DATE_ID);&#xA;&#xA;-- FK đến DIM_MERCHANT&#xA;IF EXISTS (SELECT * FROM sys.foreign_keys WHERE name = 'FK_FACT_MERCHANT')&#xA;    ALTER TABLE FACT_TRANSACTION DROP CONSTRAINT FK_FACT_MERCHANT;&#xA;ALTER TABLE FACT_TRANSACTION&#xA;ADD CONSTRAINT FK_FACT_MERCHANT&#xA;FOREIGN KEY (MERCHANT_ID) REFERENCES DIM_MERCHANT(MERCHANT_ID);&#xA;&#xA;-- FK đến DIM_DEVICE&#xA;IF EXISTS (SELECT * FROM sys.foreign_keys WHERE name = 'FK_FACT_DEVICE')&#xA;    ALTER TABLE FACT_TRANSACTION DROP CONSTRAINT FK_FACT_DEVICE;&#xA;ALTER TABLE FACT_TRANSACTION&#xA;ADD CONSTRAINT FK_FACT_DEVICE&#xA;FOREIGN KEY (DEVICE_ID) REFERENCES DIM_DEVICE(DEVICE_ID);&#xA;&#xA;-- FK đến DIM_LOCATION_TRANSACTION&#xA;IF EXISTS (SELECT * FROM sys.foreign_keys WHERE name = 'FK_FACT_LOCATION')&#xA;    ALTER TABLE FACT_TRANSACTION DROP CONSTRAINT FK_FACT_LOCATION;&#xA;ALTER TABLE FACT_TRANSACTION&#xA;ADD CONSTRAINT FK_FACT_LOCATION&#xA;FOREIGN KEY (LOCATION_TRANSACTION_ID) REFERENCES DIM_LOCATION_TRANSACTION(LOCATION_TRANSACTION_ID);&#xA;&#xA;-- FK đến DIM_TRANSACTION_TYPE&#xA;IF EXISTS (SELECT * FROM sys.foreign_keys WHERE name = 'FK_FACT_TRANSTYPE')&#xA;    ALTER TABLE FACT_TRANSACTION DROP CONSTRAINT FK_FACT_TRANSTYPE;&#xA;ALTER TABLE FACT_TRANSACTION&#xA;ADD CONSTRAINT FK_FACT_TRANSTYPE&#xA;FOREIGN KEY (TRANSACTION_TYPE_ID) REFERENCES DIM_TRANSACTION_TYPE(TRANSACTION_TYPE_ID);&#xA;GO&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
