  <Source dwd:design-time-name="7b6e575c-41dd-4bbe-819b-894631da9685">
    <DataSourceViewID>Dataware House Bank Transaction Fraund</DataSourceViewID>
  </Source>
  <MdxScripts>
    <MdxScript dwd:design-time-name="6c727fc7-94eb-4dc2-949d-79833fc10448">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE; 
CREATE DYNAMIC SET CURRENTCUBE.[Top 3 City Transaction Amount]
 AS TOPCOUNT([DIM LOCATION TRANSACTION].[Transaction City].CHILDREN,
3,[Measures].[Transaction Amount]) ;    
CREATE MEMBER CURRENTCUBE.[Measures].Top_1000_Total_Fraud_Amount
 AS AGGREGATE(
    TopCount(
        -- Tập hợp cần xếp hạng:
        FILTER(
            NONEMPTY(
                [FACT TRANSACTION].[FACT ID].Members,  -- Giả định [FACT ID] là thuộc tính ở mức độ chi tiết giao dịch
                {[Measures].[Transaction Amount]}
            ),
            ([Measures].[Is Fraud INT]) = 1 -- Chỉ lọc các giao dịch là Gian lận
        ),
        1000, -- Số lượng cần lấy
        [Measures].[Transaction Amount] -- Độ đo dùng để xếp hạng
    ),
    [Measures].[Transaction Amount] -- Độ đo được tổng hợp
), 
FORMAT_STRING = "Currency", 
VISIBLE = 1;    
CREATE MEMBER CURRENTCUBE.[Measures].Top1000FraudRate
 AS DIVIDE(
        [Measures].[Top_1000_Fraud_Count], 
        [Measures].[FACT TRANSACTION Count]
    ), 
FORMAT_STRING = "Percent", 
VISIBLE = 1;    
CREATE MEMBER CURRENTCUBE.[Measures].Top_1000_Fraud_Count
 AS Count(
    TopCount(
        FILTER(
            NONEMPTY(
                [FACT TRANSACTION].[FACT ID].Members,
                {[Measures].[Transaction Amount]}
            ),
            ([Measures].[Is Fraud Int]) = 1
        ),
        1000,
        [Measures].[Transaction Amount]
    )
), 
VISIBLE = 1;     
CREATE MEMBER CURRENTCUBE.[Measures].Average_Transaction_Amount
 AS DIVIDE([Measures].[Transaction Amount], [Measures].[FACT TRANSACTION Count]), 
FORMAT_STRING = "Currency", 
VISIBLE = 1; 
CREATE DYNAMIC SET CURRENTCUBE.[Top 1 Bank Branch]
 AS TopCount(
    [DIM BANK BRANCH].[Bank Branch].Children, 
    1, 
    [Measures].[Transaction Amount]
) ; 
CREATE DYNAMIC SET CURRENTCUBE.[Top 2 Customer]
 AS TOPCOUNT([DIM CUSTOMER].[Customer Name].CHILDREN,
2, [Measures].[Transaction Amount]) ; 
CREATE DYNAMIC SET CURRENTCUBE.[Top 5 Bank Branch Transaction Amount]
 AS TOPCOUNT([DIM BANK BRANCH].[Bank Branch].CHILDREN,
5,[Measures].[Transaction Amount]) ; 
CREATE DYNAMIC SET CURRENTCUBE.[Fraud_Transaction_Higher_95000]
 AS FILTER(
    NONEMPTY(
        [DIM CUSTOMER].[CUSTOMER ID].[CUSTOMER ID].Members,
        [Measures].[Transaction Amount]
    ),
    [Measures].[Is Fraud] &gt;= 1 
    AND [Measures].[Transaction Amount] &gt; 95000
) ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Transaction Amount Higher 95000]
 AS IIF(
    [Measures].[Transaction Amount] &gt; 95000,
    [Measures].[Transaction Amount],
    NULL
)

[Avegare Amount]
[Measures].[Total Transaction Amount]/[Measures].[FACT TRANSACTION Count], 
VISIBLE = 1  ;     
CREATE MEMBER CURRENTCUBE.[Measures].Total_Fraud_Amount
 AS DIVIDE(
    (
        [Measures].[Transaction Amount], 
        [FACT TRANSACTION].[Is Fraud Int].&amp;[1]
    ), 
    [Measures].[Total Fraud]
), 
FORMAT_STRING = "Currency", 
VISIBLE = 1;   
CREATE DYNAMIC SET CURRENTCUBE.[Top10BankBranchExceptKavaratti]
 AS TOPCOUNT(
    EXCEPT(
        [DIM BANK BRANCH].[Bank Branch].[Bank Branch].MEMBERS,
        {[DIM BANK BRANCH].[Bank Branch].&amp;[Kavaratti Branch]}
    ),
    10, 
    [Measures].[Total_Fraud_Amount]
);   
CREATE DYNAMIC SET CURRENTCUBE.[Top5ThanhPho]
 AS TOPCOUNT(
    [DIM LOCATION TRANSACTION].[Transaction City].[Transaction City].MEMBERS,
    5,
    [Measures].[Total_Fraud_Amount]
);     
CREATE MEMBER CURRENTCUBE.[Measures].Average_Fraud_Amount
 AS DIVIDE(
        [Measures].[Total_Fraud_Amount], /* Tử số: Tổng tiền gian lận (Vừa tạo ở trên) */
        [Measures].[Total Fraud]  /* Mẫu số: Tổng số vụ gian lận (Measure Count của bạn) */
    ), 
FORMAT_STRING = "Currency", 
VISIBLE = 1;   
CREATE DYNAMIC SET CURRENTCUBE.[Top3LoaiThietBi]
 AS TOPCOUNT(
    [DIM DEVICE].[Device Type].[Device Type].MEMBERS,
    3,
    [Measures].[Total_Fraud_Amount]
);  
CREATE DYNAMIC SET CURRENTCUBE.[KhachHangLonHon50000]
 AS FILTER(
    [DIM CUSTOMER].[Customer Name].[Customer Name].MEMBERS,
    [Measures].[Total_Fraud_Amount] &gt; 50000
);      
CREATE MEMBER CURRENTCUBE.[Measures].Total_Transaction_Amount
 AS sum(
[FACT TRANSACTION].[FACT ID].Members,
[Measures].[Transaction Amount]
), 
FORMAT_STRING = "Currency", 
VISIBLE = 1; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>